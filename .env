# riscv-action-runner 环境变量配置
# 复制本文件为 .env 后填写，或直接在 shell 中 export。
# systemd EnvironmentFile 格式：KEY=value，不要写 export。

# ══════════════════════════════════════════════════════════════════
# 必填
# ══════════════════════════════════════════════════════════════════

# GitHub Personal Access Token
# Fine-grained PAT 推荐权限（对每个目标仓库）：
#   Contents: Read | Commit statuses: Read & Write | Pull requests: Read & Write
GITHUB_TOKEN=

# PR 合并的目标分支
TARGET_BRANCH=main

# ══════════════════════════════════════════════════════════════════
# 工作区模式（二选一）
# ══════════════════════════════════════════════════════════════════

# "git"（单仓库，默认）或 "repo"（多仓库 manifest）
# WORKSPACE_MODE=git

# ── git 模式（WORKSPACE_MODE=git 时必填）────────────────────────
GITHUB_REPO=

# ── repo 模式（WORKSPACE_MODE=repo 时必填）──────────────────────
# MANIFEST_REPO=org/manifest   （只写 owner/repo，勿加 .git）
# MANIFEST_BRANCH=main
# MANIFEST_FILE=default.xml
# manifest 里 remote fetch 为相对路径（如 ../spacemit-robotics）时，
# 可显式指定 GitHub 用户名/组织，用于拼 owner/repo；留空则自动从 fetch 推断
# MANIFEST_GITHUB_ORG=spacemit-robotics
# 显式指定要监听的子仓库（逗号分隔）；留空则从 manifest 自动解析
# WATCH_REPOS=org/repo1,org/repo2

# ══════════════════════════════════════════════════════════════════
# 可选：工作区路径与超时
# ══════════════════════════════════════════════════════════════════

# 工作区根目录，默认 ./workspace
# WORKSPACE_DIR=./workspace

# GitHub API 轮询间隔（秒），默认 15
# POLL_INTERVAL=15

# 单个 step 最大执行时间（秒），超时强制杀进程树，默认 3600
# STEP_TIMEOUT=3600

# ══════════════════════════════════════════════════════════════════
# 可选：调度策略
# ══════════════════════════════════════════════════════════════════

# 最大并行 job 数（不同 repo 才可并行）；repo 模式强制为 1，默认 1
# MAX_PARALLEL_JOBS=1

# 同一 PR 有新 push 时，取消旧的 pending job；默认 true
# CANCEL_SUPERSEDED=true

# ══════════════════════════════════════════════════════════════════
# 可选：上报与日志
# ══════════════════════════════════════════════════════════════════

# 是否在 PR 贴/编辑评论（入队/开始/完成），默认 true
# POST_PR_COMMENT=true

# 构建日志存储目录，默认 ./logs
# LOG_DIR=./logs

# 机器标识，显示在 Commit Status 描述和 PR 评论中，默认 deb1
# RUNNER_BOARD=deb1

# ══════════════════════════════════════════════════════════════════
# 可选：安全
# ══════════════════════════════════════════════════════════════════

# 允许触发构建的 GitHub 用户名白名单（逗号分隔）；留空 = 不限制
# ALLOWED_AUTHORS=alice,bob,carol
