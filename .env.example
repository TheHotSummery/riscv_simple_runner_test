# 复制为 .env 或直接在 shell 中 export（本程序仅读取进程环境变量，不自动加载 .env 文件）

# 必填：GitHub PAT（需具备 repo、checks 等权限）
GITHUB_TOKEN=

# 必填：仓库 owner/repo
GITHUB_REPO=

# 必填：监听分支
TARGET_BRANCH=main

# 可选：轮询间隔（秒），默认 15
# POLL_INTERVAL=15

# 可选：克隆与执行工作流的目录，默认 ./workspace（相对于启动时当前工作目录）
# WORKSPACE_DIR=./workspace

# 可选：单个 step 最大执行时间（秒），默认 3600；超时将终止整棵 shell 子进程树
# STEP_TIMEOUT=3600
