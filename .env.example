# 复制为 .env 或直接在 shell 中 export（python-dotenv 会在启动时加载）

# ── 必填 ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=
TARGET_BRANCH=main

# ── 单仓库（默认 WORKSPACE_MODE=git）────────────────────────────────
GITHUB_REPO=owner/repo

# ── 多仓库 repo manifest（WORKSPACE_MODE=repo）───────────────────────
# WORKSPACE_MODE=repo
# MANIFEST_REPO=org/manifest
# MANIFEST_BRANCH=main
# MANIFEST_FILE=default.xml
# MANIFEST_GITHUB_ORG=spacemit-robotics
# WATCH_REPOS=spacemit-robotics/build,spacemit-robotics/kernel

# ── 可选 ─────────────────────────────────────────────────────────────
# WORKSPACE_DIR=./workspace
# WORKFLOW_DIR=./workspace/build   # 统一构建入口（最高优先级，留空=自动查找）
# POLL_INTERVAL=15
# STEP_TIMEOUT=3600
# SKIP_SUDO_STEPS=true
# MAX_PARALLEL_JOBS=1
# LOG_DIR=./logs
# RUNNER_BOARD=deb1
# POST_PR_COMMENT=true
# ALLOWED_AUTHORS=alice,bob
